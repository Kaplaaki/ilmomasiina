extends ../layout.pug

block mainContent
  div.content-block
    p.bodyText Maksusi tapahtumaan #[strong #{event.title}] on vastaanotettu.
  if event.verificationEmail
    div.content-block
      p.bodyText #{event.verificationEmail}
  div.content-block
    p.bodyText Maksun tiedot:
    table
      each product in products
        tr
          td #{product.amount}&times;
          td #{product.name}
          td #{product.unitPriceFormatted}
      tr
        th(colspan="2") Yhteensä
        th #{totalFormatted}
  div.content-block
    p.bodyText Näet ilmoittautumisesi klikkaamalla #[a(href=cancelLink) tätä linkkiä].
